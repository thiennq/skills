    "--accent-glow": "rgba(67, 97, 238, 0.4)",
    "--text-primary": "#ffffff",
    "--text-secondary": "rgba(255, 255, 255, 0.85)",
    "--text-muted": "rgba(255, 255, 255, 0.55)",
    "--text-subtle": "rgba(255, 255, 255, 0.35)",
    "--text-ghost": "rgba(255, 255, 255, 0.15)",
    "--accent-text": "#4361ee",
    "--accent-dim": "rgba(67, 97, 238, 0.60)",
