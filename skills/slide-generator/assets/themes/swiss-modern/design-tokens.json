{
  "fonts": "@import url('https://fonts.googleapis.com/css2?family=Archivo:wght@600;800&family=Nunito:wght@400&display=swap');",
  "variables": {
    "--bg-primary": "#ffffff",
    "--bg-secondary": "#f5f5f5",
    "--accent": "#ff3300",
    "--accent-glow": "rgba(255, 51, 0, 0.3)",
    "--text-primary": "#000000",
    "--text-secondary": "rgba(0, 0, 0, 0.85)",
    "--text-muted": "rgba(0, 0, 0, 0.55)",
    "--text-subtle": "rgba(0, 0, 0, 0.35)",
    "--text-ghost": "rgba(0, 0, 0, 0.10)",
    "--accent-text": "#ff3300",
    "--accent-dim": "rgba(255, 51, 0, 0.60)",
    "--accent-ghost": "rgba(255, 51, 0, 0.25)"
  },
  "compatibility": {
    "compatible": [
      "image-left",
      "two-column"
    ],
    "avoid": [
      "center",
      "image-right"
    ]
  }
}